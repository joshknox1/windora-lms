<?xml version="1.0" encoding="utf-8"?>
<plugin name="Pandora" version="0.1.0" minTargetVersion="8.0.0" maxTargetVersion="9.0.99">

    <title>Pandora</title>
    <description>Stream Pandora stations to your Squeezeboxen. Backed by
    windora-lms's vendored copy of the reverse-engineered Pandora client.
    Requires the windora-lms-helper service running on the LMS host
    (see scripts/windora-lms-helper.service).</description>
    <author>windora-lms contributors</author>
    <email></email>

    <url>https://github.com/anomalyco/windora-lms</url>
    <copyright>MIT</copyright>
    <license>MIT</license>

    <tags>music streaming pandora</tags>

    <prefs>
        <preference name="helperHost" type="text" defaultValue="127.0.0.1">
            <label>Windora helper host</label>
            <min>1</min>
            <max>64</max>
        </preference>
        <preference name="helperPort" type="integer" defaultValue="9123">
            <label>Windora helper port</label>
            <min>1</min>
            <max>65535</max>
        </preference>
        <preference name="authEmail" type="text" defaultValue="">
            <label>Pandora email</label>
        </preference>
    </prefs>

    <component
        name="Settings"
        module="Plugins::Pandora::Settings"
        screen="Settings"
    />

</plugin>
